// =============================================================================
// OdontoFlow - Schema Prisma
// Multi-tenant SaaS de Gerenciamento Clínico Odontológico
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum TenantPlan {
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum UserRole {
  ADMIN
  DENTIST
  SECRETARY
}

enum AppointmentStatus {
  AGENDADO
  CONFIRMADO
  EM_ATENDIMENTO
  FINALIZADO
  CANCELADO
  FALTOU
  ESPERA
}

enum AppointmentType {
  PARTICULAR
  CONVENIO
}

enum Room {
  SALA_1
  SALA_2
  SALA_3
  SALA_4
}

enum PaymentMethod {
  PIX
  CREDITO
  DEBITO
  DINHEIRO
  CONVENIO
}

enum TransactionType {
  RECEITA
  DESPESA
}

enum Gender {
  MASCULINO
  FEMININO
  OUTRO
  NAO_INFORMADO
}

// =============================================================================
// MODELS
// =============================================================================

// 🏢 TENANT — Entidade máxima, representa a assinatura/empresa no SaaS
model Tenant {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  plan        TenantPlan @default(STANDARD)
  databaseUrl String?    // Futuro: isolamento por banco para Enterprise
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  clinics      Clinic[]
  users        User[]
  patients     Patient[]
  appointments Appointment[]
  products     Product[]
  suppliers    Supplier[]
  transactions Transaction[]

  @@map("tenants")
}

// 🏥 CLINIC — Filial pertencente a um Tenant
model Clinic {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  cnpj      String?  @unique
  phone     String?
  email     String?
  address   String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users        User[]
  patients     Patient[]
  appointments Appointment[]
  products     Product[]
  transactions Transaction[]
  suppliers    Supplier[]

  @@index([tenantId])
  @@map("clinics")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String
  clinicId     String
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole
  phone        String?
  cro          String?   // Conselho Regional de Odontologia (dentistas)
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  appointments Appointment[] @relation("DentistAppointments")

  @@index([tenantId])
  @@index([clinicId])
  @@index([email])
  @@map("users")
}

model Patient {
  id              String    @id @default(uuid())
  tenantId        String
  clinicId        String
  name            String
  phone           String
  email           String?
  cpf             String?
  birthDate       DateTime?
  gender          Gender    @default(NAO_INFORMADO)
  address         String?
  historyNotes    String?   @db.Text
  allergies       String?   @db.Text
  medications     String?   @db.Text
  bloodType       String?
  insuranceName   String?
  insuranceNumber String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  appointments Appointment[]

  @@unique([tenantId, cpf]) // CPF único dentro do tenant (todas as filiais)
  @@index([tenantId])
  @@index([clinicId])
  @@index([clinicId, name])
  @@map("patients")
}

model Appointment {
  id                 String            @id @default(uuid())
  tenantId           String
  clinicId           String
  patientId          String
  dentistId          String
  dateTime           DateTime
  durationMin        Int               @default(60)
  status             AppointmentStatus @default(AGENDADO)
  type               AppointmentType
  room               Room
  notes              String?           @db.Text
  cancelledAt        DateTime?
  cancellationReason String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clinic      Clinic       @relation(fields: [clinicId], references: [id])
  patient     Patient      @relation(fields: [patientId], references: [id])
  dentist     User         @relation("DentistAppointments", fields: [dentistId], references: [id])
  transaction Transaction?

  @@index([tenantId])
  @@index([clinicId])
  @@index([clinicId, dateTime])
  @@index([clinicId, patientId])
  @@index([clinicId, dentistId])
  @@index([clinicId, status])
  @@map("appointments")
}

model Product {
  id          String    @id @default(uuid())
  tenantId    String
  clinicId    String
  supplierId  String?
  name        String
  description String?
  category    String?
  unit        String    @default("unidade")
  quantity    Int
  minQuantity Int
  costPrice   Decimal?  @db.Decimal(10, 2)
  expiryDate  DateTime?
  batchNumber String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clinic   Clinic    @relation(fields: [clinicId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@index([tenantId])
  @@index([clinicId])
  @@index([clinicId, category])
  @@map("products")
}

model Supplier {
  id        String    @id @default(uuid())
  tenantId  String
  clinicId  String
  name      String
  cnpj      String?
  phone     String?
  email     String?
  contact   String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clinic   Clinic    @relation(fields: [clinicId], references: [id])
  products Product[]

  @@index([tenantId])
  @@index([clinicId])
  @@map("suppliers")
}

model Transaction {
  id            String          @id @default(uuid())
  tenantId      String
  clinicId      String
  appointmentId String?         @unique
  type          TransactionType
  amount        Decimal         @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  description   String?
  category      String?
  paidAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clinic      Clinic       @relation(fields: [clinicId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@index([clinicId])
  @@index([clinicId, type])
  @@index([clinicId, createdAt])
  @@index([clinicId, paymentMethod])
  @@map("transactions")
}
